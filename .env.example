# Open Wallet Log - Environment Configuration Template
# Copy this file to .env and update the values

# Application Environment
APP_ENV=development
APP_DEBUG=true

# Database Configuration
DB_HOST=db
DB_NAME=openwalletlog
DB_USER=openwalletlog
DB_PASS=openwalletlog123
DB_ROOT_PASS=rootpassword

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES=86400

# SMTP / Email Configuration (for Mailpit dev server)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@openwalletlog.local

# App URL
APP_URL=http://localhost:80
