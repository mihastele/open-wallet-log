{
    "name": "openwalletlog/enterprise-finance",
    "description": "Open Wallet Log - A comprehensive Progressive Web App for financial management",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Open Wallet Log Team",
            "email": "support@openwalletlog.com"
        }
    ],
    "require": {
        "php": ">=7.4",
        "ext-pdo": "*",
        "ext-json": "*",
        "ext-openssl": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "squizlabs/php_codesniffer": "^3.6",
        "phpstan/phpstan": "^1.0"
    },
    "suggest": {
        "firebase/php-jwt": "For enhanced JWT token handling",
        "phpmailer/phpmailer": "For email notifications and password reset",
        "vlucas/phpdotenv": "For environment variable management",
        "monolog/monolog": "For advanced logging capabilities",
        "ramsey/uuid": "For UUID generation for account numbers"
    },
    "autoload": {
        "psr-4": {
            "OpenWalletLog\\": "api/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "cs-check": "phpcs",
        "cs-fix": "phpcbf",
        "analyze": "phpstan analyse"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}
